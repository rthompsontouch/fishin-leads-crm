# =============================================================================
# FISHIN LEADS CRM — ENV VARS
# =============================================================================
#
# Supabase dashboard may show NEW names:
#   • Publishable key  → safe in the browser (use below)
#   • Secret key         → backend ONLY — never VITE_* — bypasses RLS
#
# If you still see “Legacy API keys”: anon = publishable, service_role = secret.
#
# Postgres URI (db....:5432) is for CLI/DB tools only — not for this React app.
# =============================================================================

# Project URL (Dashboard → Project Settings → API — “Project URL”)
VITE_SUPABASE_URL=https://bwbsxgjvuxuedejxusnv.supabase.co

# Publishable key (starts with sb_publishable_...)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: if your project still uses legacy JWT “anon” key instead:
# VITE_SUPABASE_ANON_KEY=

# Public CRM URL (no trailing slash). Used for password-reset email redirects.
# Production (e.g. Vercel): https://your-app.vercel.app
# Local dev: leave unset to use the current origin (e.g. http://localhost:5173).
# VITE_SITE_URL=

# --- Webhook URL override (SKIP unless you know you need it) ---
# The CRM shows this URL for “website lead capture”. By default it is:
#   ${VITE_SUPABASE_URL}/functions/v1/website-lead-capture
# (your Edge Function on Supabase — NOT your Vercel URL). You do NOT need this
# variable on Vercel for a normal setup. Only set the line below if you use a
# proxy or a different public URL for the same function.
# VITE_WEBSITE_LEAD_CAPTURE_URL=

# --- Web Push (PWA) ---
# Enable push notifications in Settings. This CRM uses Web Push with VAPID.
#
# You MUST generate VAPID keys once and store:
#   - private key as Supabase Edge Secret `VAPID_KEYS_JSON` (stringified exportVapidKeys())
#   - public key as VITE_VAPID_PUBLIC_KEY (browser only)
VITE_VAPID_PUBLIC_KEY=

# --- CLI / Postgres (never VITE_*, never import in React) ---
# DIRECT_POSTGRES_URL=postgresql://postgres:PASSWORD@db.bwbsxgjvuxuedejxusnv.supabase.co:5432/postgres
# SUPABASE_ACCESS_TOKEN=
