# =============================================================================
# FISHIN LEADS CRM — ENV VARS
# =============================================================================
#
# Supabase dashboard may show NEW names:
#   • Publishable key  → safe in the browser (use below)
#   • Secret key         → backend ONLY — never VITE_* — bypasses RLS
#
# If you still see “Legacy API keys”: anon = publishable, service_role = secret.
#
# Postgres URI (db....:5432) is for CLI/DB tools only — not for this React app.
# =============================================================================

# Project URL (Dashboard → Project Settings → API — “Project URL”)
VITE_SUPABASE_URL=https://bwbsxgjvuxuedejxusnv.supabase.co

# Publishable key (starts with sb_publishable_...)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: if your project still uses legacy JWT “anon” key instead:
# VITE_SUPABASE_ANON_KEY=

# --- CLI / Postgres (never VITE_*, never import in React) ---
# DIRECT_POSTGRES_URL=postgresql://postgres:PASSWORD@db.bwbsxgjvuxuedejxusnv.supabase.co:5432/postgres
# SUPABASE_ACCESS_TOKEN=
